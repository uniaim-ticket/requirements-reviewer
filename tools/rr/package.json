{
  "name": "rr",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "rr - Requirements Review: a local UI to review and revise HTML deliverables with Claude Code",
  "license": "MIT",
  "author": "sasanquaneuf",
  "homepage": "https://github.com/uniaim-ticket/requirements-reviewer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uniaim-ticket/requirements-reviewer.git",
    "directory": "tools/rr"
  },
  "bugs": {
    "url": "https://github.com/uniaim-ticket/requirements-reviewer/issues"
  },
  "keywords": [
    "requirements",
    "review",
    "html",
    "claude-code",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "rr": "./dist/cli/index.js"
  },
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "cli": "tsx src/cli/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "fastify": "^5.8.5",
    "node-html-parser": "^6.1.13",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
